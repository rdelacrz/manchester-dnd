# Set APP_ENV_FILE to load a different dotenv file at process startup.
APP_ACCESS_MODE=local
RUST_LOG=manchester_dnd=debug,tower_http=info
DATABASE_URL=sqlite://data/manchester-arcana.db?mode=rwc
EVENT_PROMPT_DIR=prompts/events/private

# Text and image models may use different providers or models. "disabled" keeps
# local development deterministic and prevents accidental paid API calls.
TEXT_LLM_BACKEND=disabled
TEXT_LLM_BASE_URL=https://api.example.com/v1
TEXT_LLM_API_KEY=
TEXT_LLM_MODEL=
TEXT_LLM_TIMEOUT_SECONDS=60
TEXT_LLM_TEMPERATURE=0.7
TEXT_LLM_MAX_OUTPUT_TOKENS=1400

IMAGE_LLM_BACKEND=disabled
IMAGE_LLM_BASE_URL=https://api.example.com/v1
IMAGE_LLM_API_KEY=
IMAGE_LLM_MODEL=
IMAGE_LLM_TIMEOUT_SECONDS=90
IMAGE_LLM_SIZE=1024x1024
