# Set APP_ENV_FILE to load a different dotenv file at process startup.
APP_ACCESS_MODE=local
RUST_LOG=manchester_dnd=debug,tower_http=info
# MongoDB is the new authoritative persistence foundation. These values match
# compose.yaml development-only defaults. Rotate every credential in hosted
# deployments. Hosted MONGODB_URI must use mongodb+srv or tls=true with valid
# certificates; schema application is CLI-only and verify-only at app startup.
MONGODB_DATABASE=manchester_dnd
MONGODB_URI=mongodb://manchester_app:dev-app-password@127.0.0.1:27017/?authSource=admin&replicaSet=rs0&directConnection=true
# `mongo-admin schema apply` prefers this schema URL. App startup ignores it;
# do not expose schema credentials to the app process in hosted deployments.
MONGODB_SCHEMA_URI=mongodb://manchester_schema:dev-schema-password@127.0.0.1:27017/?authSource=admin&replicaSet=rs0&directConnection=true
MONGODB_MAX_POOL_SIZE=10
MONGODB_MIN_POOL_SIZE=0
MONGODB_CONNECT_TIMEOUT_MS=5000
MONGODB_SERVER_SELECTION_TIMEOUT_MS=5000
MONGODB_OPERATION_TIMEOUT_MS=30000
MONGODB_TRANSACTION_TIMEOUT_MS=10000
MONGODB_TRANSACTION_MAX_RETRIES=3
MONGO_SCHEMA_APPLY_ON_START=true
MONGO_ROOT_USERNAME=root
MONGO_ROOT_PASSWORD=dev-root-password
MONGO_APP_USERNAME=manchester_app
MONGO_APP_PASSWORD=dev-app-password
MONGO_SCHEMA_USERNAME=manchester_schema
MONGO_SCHEMA_PASSWORD=dev-schema-password
MONGO_REPLICA_SET_KEY=bWFuY2hlc3Rlci1kbmQtZGV2ZWxvcG1lbnQtcmVwbGljYS1zZXQta2V5

# Optional disposable cache/pub-sub. Redis plaintext is acceptable only on
# loopback/private Compose networking; use rediss:// across untrusted networks.
DRAGONFLY_ENABLED=false
DRAGONFLY_URL=redis://default:dev-cache-password@127.0.0.1:6379/0
DRAGONFLY_POOL_SIZE=8
DRAGONFLY_TIMEOUT_MS=2000
DRAGONFLY_PASSWORD=dev-cache-password
DRAGONFLY_MAX_MEMORY=512mb
DRAGONFLY_THREADS=1

# Authentication (hosted mode requires secure cookies and a canonical origin).
# Hosted mode remains fail-closed until the evidence gate is passed.
AUTH_SESSION_IDLE_LIFETIME_SECONDS=1800
AUTH_SESSION_ABSOLUTE_LIFETIME_SECONDS=28800
AUTH_MAX_ACTIVE_SESSIONS=5
AUTH_MAX_HASH_CONCURRENCY=4
AUTH_THROTTLE_WINDOW_SECONDS=300
AUTH_THROTTLE_BLOCK_AFTER_ATTEMPTS=10
AUTH_THROTTLE_BLOCK_SECONDS=300
AUTH_COOKIE_SECURE=true
AUTH_CANONICAL_ORIGIN=
AUTH_ARGON2_MEMORY_KIB=65536
AUTH_ARGON2_ITERATIONS=3
AUTH_ARGON2_PARALLELISM=4
# Each HMAC secret must contain at least 32 random bytes. Email AEAD key must be
# standard base64 for exactly 32 random bytes. Keep lookup and AEAD keys
# separate. Local code defaults are visibly development-only; hosted mode
# requires all values below explicitly.
AUTH_THROTTLE_HMAC_KEY=
AUTH_EMAIL_ENCRYPTION_KEY_B64=
AUTH_EMAIL_ENCRYPTION_KEY_ID=email-key:2026-01
AUTH_EMAIL_LOOKUP_HMAC_KEY=
# Startup reads only the three compiled, exactly pinned directories below this
# root. The default theme must be one of the two bundled presentation packs.
CONTENT_PACK_ROOT=content/packs
CONTENT_DEFAULT_THEME_PACK_ID=dev.manchester-arcana.rainbound-borough
EVENT_PROMPT_DIR=prompts/events/private
INSPIRATION_ENABLED=false
# Generated with mode 0600 on first startup. Back it up with MongoDB/object
# metadata or deterministic saved campaigns cannot be replayed after host loss.
RNG_MASTER_KEY_FILE=data/rng-master.key

# Text and image models may use different providers or models. "disabled" keeps
# local development deterministic and prevents accidental paid API calls.
# Use "fake" for network-free authored demo output.
TEXT_LLM_BACKEND=disabled
TEXT_LLM_BASE_URL=https://api.example.com/v1
TEXT_LLM_API_KEY=
TEXT_LLM_MODEL=
TEXT_LLM_TIMEOUT_SECONDS=60
TEXT_LLM_TEMPERATURE=0.7
TEXT_LLM_MAX_OUTPUT_TOKENS=1400
TEXT_LLM_ESTIMATED_REQUEST_COST_MICROUSD=0

IMAGE_LLM_BACKEND=disabled
IMAGE_LLM_BASE_URL=https://api.example.com/v1
IMAGE_LLM_API_KEY=
IMAGE_LLM_MODEL=
IMAGE_LLM_TIMEOUT_SECONDS=90
IMAGE_LLM_SIZE=1024x1024
IMAGE_LLM_ESTIMATED_REQUEST_COST_MICROUSD=0

# Body-free durable budget receipts reserve these limits before any provider
# call. A zero cost budget intentionally blocks non-zero-cost provider profiles.
GENERATION_CAMPAIGN_REQUEST_BUDGET=256
GENERATION_TURN_REQUEST_BUDGET=8
GENERATION_CAMPAIGN_TOKEN_BUDGET=4000000
GENERATION_TURN_TOKEN_BUDGET=512000
GENERATION_CAMPAIGN_LATENCY_BUDGET_MILLISECONDS=3600000
GENERATION_TURN_LATENCY_BUDGET_MILLISECONDS=600000
GENERATION_CAMPAIGN_COST_BUDGET_MICROUSD=0
GENERATION_TURN_COST_BUDGET_MICROUSD=0
GENERATION_MAX_CAMPAIGN_CONCURRENCY=2
GENERATION_WORKER_BATCH_SIZE=4
